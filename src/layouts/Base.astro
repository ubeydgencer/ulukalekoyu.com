---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { LOCALES, DIR, HTML_LANG, OG_LOCALE, localeUrl, localePath, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  page: string;
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonld?: string;
}
const {
  lang, page, title, description = '',
  ogTitle = title, ogDescription = description,
  ogImage = 'https://ulukalekoyu.com/images/koy-eski.jpg',
  ogType = 'website', noindex = false, jsonld,
} = Astro.props;

const canonical = localeUrl(lang, page);
const siteName: Record<Lang, string> = {
  tr: 'Ulukale Köyü Dijital Arşivi',
  en: 'Ulukale Village Digital Archive',
  ar: 'أرشيف قرية أولوكالة الرقمي',
};
const fontHref = lang === 'ar'
  ? 'https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Lora:wght@400;600;700&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap';
---
<!DOCTYPE html>
<html lang={HTML_LANG[lang]} dir={DIR[lang]}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-XQX8PEVH17"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-XQX8PEVH17');
</script>
<title>{title}</title>
{description && <meta name="description" content={description} />}
<meta name="author" content="Ubeyd Gençer" />
<meta name="robots" content={noindex ? 'noindex' : 'index, follow, max-image-preview:large'} />
<link rel="canonical" href={canonical} />
{LOCALES.map((l) => <link rel="alternate" hreflang={l} href={localeUrl(l, page)} />)}
<link rel="alternate" hreflang="x-default" href={localeUrl('tr', page)} />
<meta name="theme-color" content="#a9542d" />

<meta property="og:site_name" content={siteName[lang]} />
<meta property="og:locale" content={OG_LOCALE[lang]} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={ogTitle} />
{ogDescription && <meta property="og:description" content={ogDescription} />}
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle} />
{ogDescription && <meta name="twitter:description" content={ogDescription} />}
<meta name="twitter:image" content={ogImage} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="Ulukale" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href={fontHref} rel="stylesheet" />
<link rel="stylesheet" href="/css/style.css" />
{jsonld && <script type="application/ld+json" set:html={jsonld} />}
</head>
<body>
<Header lang={lang} page={page} />
<slot />
<Footer lang={lang} />
</body>
</html>
