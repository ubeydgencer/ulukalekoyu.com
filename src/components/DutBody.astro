---
import Gallery from './Gallery.astro';
import { localePath, type Lang } from '../lib/i18n';
import { DUT } from '../data/dut';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = DUT[lang];
const stepIcons = [
  '<path d="M11 20A7 7 0 0 1 4 13C4 8 8 4 13 4c1 0 7-1 7 7a7 7 0 0 1-9 9z"/><path d="M11 20c0-4 2-7 5-9"/>',
  '<rect x="3" y="6" width="18" height="14" rx="1"/><path d="M3 11h18M3 15.5h18M9 6v14M15 6v14"/>',
  '<circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"/>',
  '<path d="M3 9h18l-1.6 10.3a2 2 0 0 1-2 1.7H6.6a2 2 0 0 1-2-1.7z"/><path d="M3 9l3-5M21 9l-3-5M9 13v3M12 13v3M15 13v3"/>',
];
const contact: Record<Lang, string> = { tr: 'bizimle paylaşabilir', en: 'share them with us', ar: 'مشاركتها معنا' };
const contact2: Record<Lang, string> = { tr: 'iletişime geçin', en: 'contact us', ar: 'التواصل معنا' };
---
<section class="page-hero">
  <div class="container">
    <div class="crumbs"><a href={localePath(lang, 'index')}>{t.home}</a> · {t.crumb}</div>
    <span class="kicker">{t.kicker}</span><h1>{t.h1}</h1><p>{t.intro}</p>
  </div>
</section>

<section class="section-tight alt-bg">
  <div class="container">
    <div class="stats">{t.stats.map((s) => <div class="stat"><div class="num">{s.num}</div><div class="lbl">{s.lbl}</div></div>)}</div>
  </div>
</section>

<section>
  <div class="container narrow prose">
    <div class="dut-motif">
      <svg viewBox="0 0 150 110" aria-hidden="true">
        <defs>
          <g id="dutBerry">
            <g fill="#fbf6ec" stroke="#c2ad80" stroke-width="1.1">
              <circle cx="0" cy="-18" r="6.5"/><circle cx="-7" cy="-12" r="6.5"/><circle cx="7" cy="-11" r="6.5"/>
              <circle cx="0" cy="-6" r="7"/><circle cx="-8" cy="0" r="6.5"/><circle cx="8" cy="1" r="6.5"/>
              <circle cx="0" cy="5" r="7"/><circle cx="-6" cy="12" r="6"/><circle cx="7" cy="12" r="6"/><circle cx="0" cy="18" r="5.5"/>
            </g>
            <g fill="#ffffff" opacity="0.7"><circle cx="-3" cy="-15" r="1.8"/><circle cx="-9" cy="-2" r="1.5"/></g>
            <g fill="#3a3026">
              <ellipse cx="-2" cy="-16" rx="1.1" ry="0.7"/><ellipse cx="4" cy="-13" rx="1" ry="0.6"/><ellipse cx="-6" cy="-9" rx="1" ry="0.6"/>
              <ellipse cx="5" cy="-4" rx="1.1" ry="0.7"/><ellipse cx="-7" cy="2" rx="1" ry="0.6"/><ellipse cx="2" cy="0" rx="1" ry="0.6"/>
              <ellipse cx="6" cy="7" rx="1" ry="0.6"/><ellipse cx="-3" cy="10" rx="1" ry="0.6"/><ellipse cx="3" cy="14" rx="0.9" ry="0.6"/><ellipse cx="-5" cy="5" rx="0.9" ry="0.6"/>
            </g>
          </g>
        </defs>
        <ellipse cx="96" cy="95" rx="30" ry="5" fill="#2c241c" opacity="0.06"/>
        <path d="M30 26 C 8 37 9 65 35 73 C 51 61 50 34 30 26 Z" fill="#6b7146"/>
        <path d="M31 29 C 33 45 34 60 35 71" fill="none" stroke="#8a9a59" stroke-width="1.4"/>
        <path d="M32 40 L 21 37 M33 52 L 22 53 M33 35 L 42 31 M34 47 L 44 45" stroke="#8a9a59" stroke-width="1" opacity="0.7"/>
        <path d="M92 84 C 95 92 104 93 110 89" fill="none" stroke="#8a9a59" stroke-width="2"/>
        <use href="#dutBerry" transform="translate(86,40) rotate(-15) scale(0.82)"/>
        <use href="#dutBerry" transform="translate(114,58) rotate(20) scale(0.86)"/>
        <use href="#dutBerry" transform="translate(90,72) rotate(-3) scale(0.98)"/>
      </svg>
    </div>
    <div class="section-head"><span class="kicker">{t.motifK}</span><h2>{t.motifH}</h2></div>
    {t.introP.map((p, i) => <p class={i === 0 ? 'drop' : undefined} set:html={p} />)}
  </div>
</section>

<section class="alt-bg">
  <div class="container">
    <div class="section-head"><span class="kicker">{t.procK}</span><h2>{t.procH}</h2><p>{t.procP}</p></div>
    <div class="process">
      {t.steps.map((s, i) => (
        <div class="step">
          <div class="pnum"><svg class="ico" viewBox="0 0 24 24" set:html={stepIcons[i]} /></div>
          <div class="pcontent"><span class="pstep">{s.step}</span><h4 set:html={s.h4} /><p set:html={s.p} /></div>
        </div>
      ))}
    </div>
    <div class="memory" style="margin-top:30px"><blockquote>{t.muhtarQ}</blockquote><cite>{t.muhtarC}</cite></div>
  </div>
</section>

<section>
  <div class="container narrow prose">
    <div class="section-head"><span class="kicker">{t.womenK}</span><h2>{t.womenH}</h2></div>
    <p set:html={t.womenP} />
    <div class="memory" style="margin:24px 0;"><blockquote>{t.q2}</blockquote><cite>{t.c2}</cite></div>
    <div class="memory"><blockquote>{t.q3}</blockquote><cite>{t.c3}</cite></div>
  </div>
</section>

<section class="alt-bg">
  <div class="container">
    <div class="section-head"><span class="kicker">{t.econK}</span><h2>{t.econH}</h2></div>
    <div class="grid grid-2">{t.cards.map((c) => <div class="card"><h3>{c.h3}</h3><p set:html={c.p} /></div>)}</div>
    <div class="note" style="margin-top:26px" set:html={t.giNote.replace(contact[lang], `<a href="${localePath(lang,'iletisim')}">${contact[lang]}</a>`)} />
    <div class="note" style="margin-top:14px" set:html={t.healthNote} />
  </div>
</section>

<section>
  <div class="container narrow">
    <div class="memory"><blockquote>{t.endemicQ}</blockquote><cite>{t.endemicC}</cite></div>
    <p class="note" style="margin-top:24px;">{t.sources}</p>
  </div>
</section>

<section class="alt-bg">
  <div class="container">
    <div class="section-head"><span class="kicker">{t.galK}</span><h2>{t.galH}</h2><p>{t.galP}</p></div>
    <Gallery lang={lang} group="dut" />
    <p class="note" style="margin-top:24px" set:html={t.galNote.replace(contact2[lang], `<a href="${localePath(lang,'iletisim')}">${contact2[lang]}</a>`)} />
  </div>
</section>

<section class="alt-bg">
  <div class="container">
    <div class="cta"><h2>{t.ctaH2}</h2><p>{t.ctaP}</p><a href={localePath(lang, 'iletisim')} class="btn btn-ghost">{t.ctaBtn}</a></div>
  </div>
</section>
