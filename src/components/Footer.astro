---
import { FOOTER, localePath, type Lang } from '../lib/i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const heart = 'M12 21s-7.5-4.7-9.7-9.2C.9 8.6 2.4 5 6 5c2 0 3.2 1.1 4 2.3C10.8 6.1 12 5 14 5c3.6 0 5.1 3.6 3.7 6.8C19.5 16.3 12 21 12 21z';
---
<footer class="footer">
  <div class="container">
    <div class="cols">
      <div>
        <div class="brand-f">{FOOTER.brand[lang]}</div>
        <p class="desc">{FOOTER.desc[lang]}</p>
      </div>
      <div>
        <h4>{FOOTER.archive[lang]}</h4>
        <ul>
          <li><a href={localePath(lang, 'tarih')}>{lang === 'tr' ? 'Tarih' : lang === 'en' ? 'History' : 'التاريخ'}</a></li>
          <li><a href={localePath(lang, 'mimari')}>{lang === 'tr' ? 'Tarihi Yapılar' : lang === 'en' ? 'Historic Buildings' : 'المباني التاريخية'}</a></li>
          <li><a href={localePath(lang, 'dut')}>{FOOTER.ozelDut[lang]}</a></li>
          <li><a href={localePath(lang, 'arsiv')}>{lang === 'tr' ? 'Fotoğraf Arşivi' : lang === 'en' ? 'Photo Archive' : 'أرشيف الصور'}</a></li>
          <li><a href={localePath(lang, 'basin')}>{FOOTER.ulusalBasin[lang]}</a></li>
        </ul>
      </div>
      <div>
        <h4>{FOOTER.contact[lang]}</h4>
        <ul>
          <li><a href={localePath(lang, 'iletisim')}>{FOOTER.contribute[lang]}</a></li>
          <li><a href="mailto:merhaba@ulukalekoyu.com">merhaba@ulukalekoyu.com</a></li>
          <li>{FOOTER.loc[lang]}</li>
          <li>39.025°N, 39.036°E</li>
        </ul>
      </div>
    </div>
    <div class="bottom">
      <span>© <span id="yil"></span> ulukalekoyu.com — Ubeyd Gençer</span>
      <span>{FOOTER.dedication[lang]} <svg class="ico-heart" viewBox="0 0 24 24"><path d={heart}/></svg></span>
    </div>
  </div>
</footer>
{lang === 'ar'
  ? <script is:inline>document.getElementById('yil').textContent = String(new Date().getFullYear()).replace(/[0-9]/g,function(d){return '٠١٢٣٤٥٦٧٨٩'[+d];});</script>
  : <script is:inline>document.getElementById('yil').textContent = new Date().getFullYear();</script>}
<script is:inline src="/js/ptr.js" defer></script>
