---
import { localePath, type Lang } from '../lib/i18n';
import { HAFIZA, HAFIZA_CARDS } from '../data/hafiza';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = HAFIZA[lang];
const I: Record<string, string> = {
  ev: '<path d="M3 11l9-7 9 7"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/>',
  muzik: '<path d="M9 18V6l10-2v12"/><circle cx="6.5" cy="18" r="2.5"/><circle cx="16.5" cy="16" r="2.5"/>',
  bugday: '<path d="M12 22V9"/><path d="M12 9c0-2.2 1.8-4 4-4 0 2.2-1.8 4-4 4z"/><path d="M12 9c0-2.2-1.8-4-4-4 0 2.2 1.8 4 4 4z"/><path d="M12 15c0-2.2 1.8-4 4-4 0 2.2-1.8 4-4 4z"/><path d="M12 15c0-2.2-1.8-4-4-4 0 2.2 1.8 4 4 4z"/>',
  tencere: '<path d="M4 11h16v3a6 6 0 0 1-6 6h-4a6 6 0 0 1-6-6z"/><path d="M2 11h20"/><path d="M8 11V8M12 11V7M16 11V8"/>',
  okul: '<path d="M2 8.5L12 4l10 4.5L12 13z"/><path d="M6 10.5V15c0 1.3 2.7 3 6 3s6-1.7 6-3v-4.5"/>',
  belge: '<path d="M7 3h9a2 2 0 0 1 2 2v12a3 3 0 0 0 3 3H8a2 2 0 0 1-2-2V5a2 2 0 0 0-4 0v2h2"/><path d="M10 8h5M10 12h5"/>',
};
const successUrl = 'https://ulukalekoyu.com' + localePath(lang, 'tesekkurler');
const subject: Record<Lang, string> = { tr: 'Ulukale Arşivi — Yeni Hatıra', en: 'Ulukale Archive — New Memory', ar: 'أرشيف أولوكالة — ذكرى جديدة' };
---
<section class="page-hero">
  <div class="container">
    <div class="crumbs"><a href={localePath(lang, 'index')}>{t.home}</a> · {t.crumb}</div>
    <span class="kicker">{t.kicker}</span><h1>{t.h1}</h1><p>{t.intro}</p>
  </div>
</section>

<section>
  <div class="container narrow">
    <div class="memory" style="margin-bottom:24px"><blockquote>{t.quote}</blockquote><cite>{t.cite}</cite></div>
    <div class="note" set:html={t.note} />
  </div>
</section>

<section class="alt-bg">
  <div class="container">
    <div class="section-head"><span class="kicker">{t.cardsK}</span><h2>{t.cardsH}</h2></div>
    <div class="grid grid-3">
      {HAFIZA_CARDS.map((c) => (
        <div class="card"><span class="icon"><svg class="ico" viewBox="0 0 24 24" set:html={I[c.icon]} /></span><h3>{c.h3[lang]}</h3><p>{c.p[lang]}</p></div>
      ))}
    </div>
  </div>
</section>

<section>
  <div class="container narrow">
    <div class="section-head"><span class="kicker">{t.formK}</span><h2>{t.formH}</h2><p>{t.formP}</p></div>
    <form class="form" method="POST" action="https://api.web3forms.com/submit">
      <input type="hidden" name="access_key" value="beb78eae-2ca6-4316-9fba-d94f3b58cba6" />
      <input type="hidden" name="redirect" value={successUrl} />
      <input type="hidden" name="subject" value={subject[lang]} />
      <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
      <div class="field"><label for="ad">{t.fName}</label><input type="text" id="ad" name="ad" placeholder={t.fNamePh} /></div>
      <div class="field"><label for="baglanti">{t.fConn}</label>
        <select id="baglanti" name="baglanti">{t.conn.map((o) => <option>{o}</option>)}</select>
      </div>
      <div class="field"><label for="baslik">{t.fTitle}</label><input type="text" id="baslik" name="baslik" placeholder={t.fTitlePh} /></div>
      <div class="field"><label for="hatira">{t.fMemory}</label><textarea id="hatira" name="hatira" placeholder={t.fMemoryPh} required></textarea></div>
      <div class="field"><label for="eposta">{t.fEmail}</label><input type="email" id="eposta" name="email" placeholder={t.fEmailPh} /></div>
      <button type="submit" class="btn btn-primary">{t.submit}</button>
      <p class="note" style="margin-top:18px">{t.formNote}</p>
    </form>
  </div>
</section>
