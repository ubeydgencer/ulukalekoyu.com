---
import { type Lang } from '../lib/i18n';
import { FERIBOT, FERIBOT_WORKER } from '../data/feribot';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = FERIBOT[lang];
const labels = JSON.stringify({
  next: t.nextLabel, operator: t.operatorCol, belediye: t.belediye, ozel: t.ozel,
  loading: t.loading, error: t.error, updated: t.updated,
});
---
<section class="alt-bg" id="feribot-saatleri">
  <div class="container narrow">
    <div class="section-head"><span class="kicker">{t.kicker}</span><h2>{t.h1}</h2><p>{t.intro}</p></div>
    <div id="feribot" data-worker={FERIBOT_WORKER} data-lang={lang} data-labels={labels}>
      <p class="feribot-state note">{t.loading}</p>
    </div>
    <p class="note" style="margin-top:22px">{t.note}</p>
  </div>
</section>

<style is:global>
  .ferry-card {
    border: 1px solid var(--line); border-radius: 14px; overflow: hidden;
    margin-bottom: 28px; background: #fffdfa; box-shadow: 0 2px 10px rgba(58, 48, 38, 0.05);
  }
  .ferry-card__head {
    display: flex; align-items: center; gap: 10px; padding: 14px 22px;
    background: var(--kerpic-dark);
  }
  .ferry-card__head svg { width: 22px; height: 22px; stroke: #f4ecdd; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
  .ferry-card__head h3 { margin: 0; font-family: var(--display); font-size: 1.25rem; color: #f7efe2; font-weight: 600; }
  .ferry-next {
    display: flex; flex-wrap: wrap; align-items: center; gap: 6px 22px;
    padding: 14px 22px; background: var(--parchment-2); border-bottom: 1px solid var(--line);
  }
  .ferry-next__label { font-size: 0.74rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--ink-soft); margin-inline-end: 4px; }
  .ferry-next__item { display: flex; align-items: baseline; gap: 7px; }
  .ferry-next__item span { color: var(--ink-soft); font-size: 0.9rem; }
  .ferry-next__item b { font-family: var(--display); font-size: 1.35rem; color: var(--kerpic-dark); }
  .ferry-table { width: 100%; border-collapse: collapse; }
  .ferry-table th {
    padding: 11px 22px; text-align: start; font-size: 0.72rem; letter-spacing: 1px;
    text-transform: uppercase; color: var(--ink-soft); border-bottom: 2px solid var(--line); white-space: nowrap;
  }
  .ferry-table th.mid { text-align: center; }
  .ferry-table td { padding: 9px 22px; border-bottom: 1px solid rgba(214, 199, 169, 0.5); }
  .ferry-table tbody tr:nth-child(even) { background: rgba(122, 90, 56, 0.025); }
  .ferry-table tbody tr:last-child td { border-bottom: none; }
  .ferry-table td.time { font-family: var(--display); font-size: 1.06rem; color: var(--ink); }
  .ferry-table td.op { color: var(--ink-soft); font-size: 0.82rem; text-align: center; }
  .ferry-table tr.soon { background: rgba(169, 84, 45, 0.10) !important; }
  .ferry-table tr.soon td.time { color: var(--kerpic-dark); font-weight: 700; }
  .feribot-updated { color: var(--ink-soft); font-size: 0.85rem; margin-top: 4px; }
  @media (max-width: 520px) {
    .ferry-card__head, .ferry-next, .ferry-table th, .ferry-table td { padding-inline: 16px; }
  }
</style>

<script>
  const AR = '٠١٢٣٤٥٦٧٨٩';
  const BOAT = '<svg viewBox="0 0 24 24"><path d="M3 14l1.5 5.5a2 2 0 0 0 1.9 1.5h11.2a2 2 0 0 0 1.9-1.5L22 14"/><path d="M4 14l8-2.5L20 14"/><path d="M12 11.5V5l5 2.5"/><path d="M12 5H8"/></svg>';
  const root = document.getElementById('feribot');
  if (root) {
    const lang = root.dataset.lang;
    const L = JSON.parse(root.dataset.labels || '{}');
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const ar = (s) => (lang === 'ar' ? String(s).replace(/[0-9]/g, (d) => AR[+d]) : String(s));
    const toMin = (t) => { const [h, m] = t.split(':').map(Number); return h * 60 + m; };
    const nextOf = (list, now) => list.find((t) => toMin(t) >= now) || list[0];
    const opLabel = (op) => (/zel/i.test(op || '') ? L.ozel : L.belediye);

    fetch(root.dataset.worker)
      .then((r) => { if (!r.ok) throw new Error('http'); return r.json(); })
      .then((d) => {
        if (!d.routes || !d.routes.length) throw new Error('empty');
        const now = new Date();
        const cur = now.getHours() * 60 + now.getMinutes();
        const html = d.routes.map((rt) => {
          const n1 = rt.side1Times.length ? nextOf(rt.side1Times, cur) : '';
          const n2 = rt.side2Times.length ? nextOf(rt.side2Times, cur) : '';
          const body = rt.rows.map((r) => {
            const soon = (r.from && r.from === n1) || (r.to && r.to === n2);
            return `<tr class="${soon ? 'soon' : ''}">
              <td class="time">${r.from ? ar(r.from) : '—'}</td>
              ${rt.hasOperator ? `<td class="op">${esc(opLabel(r.operator))}</td>` : ''}
              <td class="time">${r.to ? ar(r.to) : '—'}</td></tr>`;
          }).join('');
          return `<div class="ferry-card">
            <div class="ferry-card__head">${BOAT}<h3>${esc(rt.side1)} ↔ ${esc(rt.side2)}</h3></div>
            <div class="ferry-next">
              <span class="ferry-next__label">${L.next}</span>
              ${n1 ? `<span class="ferry-next__item"><span>${esc(rt.side1)}</span><b>${ar(n1)}</b></span>` : ''}
              ${n2 ? `<span class="ferry-next__item"><span>${esc(rt.side2)}</span><b>${ar(n2)}</b></span>` : ''}
            </div>
            <table class="ferry-table">
              <thead><tr>
                <th>${esc(rt.side1)} →</th>
                ${rt.hasOperator ? `<th class="mid">${L.operator}</th>` : ''}
                <th>${esc(rt.side2)} →</th>
              </tr></thead>
              <tbody>${body}</tbody>
            </table>
          </div>`;
        }).join('');
        const upd = d.updatedAt ? new Date(d.updatedAt).toLocaleDateString(lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar' : 'en-GB') : '';
        root.innerHTML = html + (upd ? `<p class="feribot-updated">${L.updated}: ${ar(upd)}</p>` : '');
      })
      .catch(() => {
        const s = root.querySelector('.feribot-state');
        if (s) s.textContent = L.error;
      });
  }
</script>
