---
import { type Lang } from '../lib/i18n';
import { FERIBOT, FERIBOT_WORKER } from '../data/feribot';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = FERIBOT[lang];
const labels = JSON.stringify({
  next: t.nextLabel, operator: t.operatorCol, belediye: t.belediye, ozel: t.ozel,
  loading: t.loading, error: t.error, updated: t.updated,
});
---
<section class="alt-bg" id="feribot-saatleri">
  <div class="container narrow">
    <div class="section-head"><span class="kicker">{t.kicker}</span><h2>{t.h1}</h2><p>{t.intro}</p></div>
    <div id="feribot" data-worker={FERIBOT_WORKER} data-lang={lang} data-labels={labels}>
      <p class="feribot-state note">{t.loading}</p>
    </div>
    <p class="note" style="margin-top:22px">{t.note}</p>
  </div>
</section>

<style>
  .feribot-route { margin-bottom: 34px; }
  .feribot-route > h3 { font-family: var(--display); font-size: 1.5rem; color: var(--kerpic-dark); margin: 0 0 12px; }
  .feribot-next {
    display: flex; flex-wrap: wrap; gap: 8px 22px; align-items: baseline;
    background: var(--parchment-2); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 14px 18px; margin-bottom: 16px;
  }
  .feribot-next .lab { font-family: var(--serif); font-weight: 700; color: var(--kerpic-dark); }
  .feribot-next b { font-size: 1.2rem; color: var(--kerpic-dark); font-family: var(--display); }
  .feribot-tablo { width: 100%; border-collapse: collapse; font-size: 0.98rem; }
  .feribot-tablo th, .feribot-tablo td { padding: 9px 14px; border-bottom: 1px solid var(--line); text-align: start; }
  .feribot-tablo thead th { color: var(--ink-soft); font-size: 0.82rem; letter-spacing: 0.5px; text-transform: uppercase; }
  .feribot-tablo td.time { font-family: var(--display); font-size: 1.05rem; color: var(--kerpic-dark); }
  .feribot-tablo td.op { color: var(--ink-soft); font-size: 0.86rem; }
  .feribot-tablo tr.soon { background: rgba(169,84,45,0.08); }
  .feribot-updated { color: var(--ink-soft); font-size: 0.85rem; margin-top: 6px; }
</style>

<script>
  const AR = '٠١٢٣٤٥٦٧٨٩';
  const root = document.getElementById('feribot');
  if (root) {
    const lang = root.dataset.lang;
    const L = JSON.parse(root.dataset.labels || '{}');
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const ar = (s) => (lang === 'ar' ? String(s).replace(/[0-9]/g, (d) => AR[+d]) : String(s));
    const toMin = (t) => { const [h, m] = t.split(':').map(Number); return h * 60 + m; };
    const nextOf = (list, now) => list.find((t) => toMin(t) >= now) || list[0];
    const opLabel = (op) => (/zel/i.test(op || '') ? L.ozel : L.belediye);

    fetch(root.dataset.worker)
      .then((r) => { if (!r.ok) throw new Error('http'); return r.json(); })
      .then((d) => {
        if (!d.routes || !d.routes.length) throw new Error('empty');
        const now = new Date();
        const cur = now.getHours() * 60 + now.getMinutes();
        const html = d.routes.map((rt) => {
          const n1 = rt.side1Times.length ? nextOf(rt.side1Times, cur) : '';
          const n2 = rt.side2Times.length ? nextOf(rt.side2Times, cur) : '';
          const body = rt.rows.map((r) => {
            const soon = (r.from && r.from === n1) || (r.to && r.to === n2);
            return `<tr class="${soon ? 'soon' : ''}">
              <td class="time">${r.from ? ar(r.from) : '—'}</td>
              ${rt.hasOperator ? `<td class="op">${esc(opLabel(r.operator))}</td>` : ''}
              <td class="time">${r.to ? ar(r.to) : '—'}</td></tr>`;
          }).join('');
          return `<div class="feribot-route">
            <h3>${esc(rt.side1)} ↔ ${esc(rt.side2)}</h3>
            <div class="feribot-next">
              <span class="lab">${L.next}</span>
              ${n1 ? `<span>${esc(rt.side1)}: <b>${ar(n1)}</b></span>` : ''}
              ${n2 ? `<span>${esc(rt.side2)}: <b>${ar(n2)}</b></span>` : ''}
            </div>
            <table class="feribot-tablo">
              <thead><tr><th>${esc(rt.side1)}</th>${rt.hasOperator ? `<th>${L.operator}</th>` : ''}<th>${esc(rt.side2)}</th></tr></thead>
              <tbody>${body}</tbody>
            </table>
          </div>`;
        }).join('');
        const upd = d.updatedAt ? new Date(d.updatedAt).toLocaleDateString(lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar' : 'en-GB') : '';
        root.innerHTML = html + (upd ? `<p class="feribot-updated">${L.updated}: ${ar(upd)}</p>` : '');
      })
      .catch(() => {
        const s = root.querySelector('.feribot-state');
        if (s) s.textContent = L.error;
      });
  }
</script>
